# ── 数据库 ──
DATABASE_URL=sqlite://db.sqlite3

# ── Redis (TaskIQ 消息队列) ──
# Ubuntu 默认: redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# ── DashScope (阿里云百炼) ──
DASHSCOPE_API_KEY=sk-xxx
DASHSCOPE_MODEL=qwen3.5-omni-plus
# Qwen3.5-Omni 纯 dashscope SDK 走原生 HTTP API
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1
DASHSCOPE_TIMEOUT_SECONDS=180

# ── FFmpeg ──
# Ubuntu 默认可直接使用系统命令 ffmpeg
FFMPEG_PATH=ffmpeg
YTDLP_PATH=.venv/bin/yt-dlp

# ── yt-dlp cookies (抖音等站点常需要) ──
# 二选一: cookies 文件路径 / 浏览器名称
# 浏览器参数支持 profile, 例如 firefox:default-release
YTDLP_COOKIES_FILE=
YTDLP_COOKIES_FROM_BROWSER=
